# Path to your local WordPress plugins directory
# On macOS with Local by Flywheel, something like:
# DEV_WORDPRESS_PLUGIN_PATH=/Users/you/Local Sites/sitename/app/public/wp-content/plugins
DEV_WORDPRESS_PLUGIN_PATH=

# API Base URL for production
# This replaces the default localhost URL in the plugin PHP during production builds.
# Must match the wp-builder-server deployment URL.
BRIXLAB_ASSISTANT_API_BASE_PRODUCTION=https://api.brixlab.dev
